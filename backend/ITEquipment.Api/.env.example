# Backend production environment variables.
# Do not commit real secret values.

ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080

ConnectionStrings__DefaultConnection=Server=your-mysql-host;Port=3306;Database=it_equipment_management_smkc;User=your-user;Password=your-password;SslMode=Required;

Jwt__Issuer=ITEquipment.Api
Jwt__Audience=ITEquipment.Frontend
Jwt__SigningKey=replace-with-a-strong-random-key-at-least-32-characters
Jwt__ExpiryMinutes=480

Bootstrap__SetupKey=replace-with-private-setup-key

Cors__AllowedOrigins__0=https://your-vercel-domain.vercel.app

# Optional company SMTP settings
Email__SmtpHost=smtp.your-company.com
Email__SmtpPort=587
Email__EnableSsl=true
Email__Username=your-smtp-user
Email__Password=your-smtp-password
Email__FromEmail=no-reply@your-company.com
Email__FromName=IT Equipment Management
